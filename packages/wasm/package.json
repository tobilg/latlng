{
  "name": "@latlng/wasm",
  "version": "0.1.0",
  "description": "Browser Web Worker and WebAssembly package for the latlng geospatial object engine",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite-plugin": {
      "types": "./dist/vite-plugin/index.d.ts",
      "import": "./dist/vite-plugin/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "homepage": "https://github.com/tobilg/latlng",
  "bugs": {
    "url": "https://github.com/tobilg/latlng/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tobilg/latlng",
    "directory": "packages/wasm"
  },
  "scripts": {
    "build:wasm": "tsc -p tsconfig.scripts.json && node .tmp/scripts/build-wasm.js",
    "build": "npm run build:wasm && vite build && tsc -p tsconfig.json --emitDeclarationOnly",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build:wasm && vitest run"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
