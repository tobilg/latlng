{
  "name": "@latlng/sdk",
  "version": "0.1.1",
  "description": "TypeScript SDK for the latlng geospatial object engine",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "homepage": "https://github.com/tobilg/latlng",
  "bugs": {
    "url": "https://github.com/tobilg/latlng/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tobilg/latlng"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.json --emitDeclarationOnly",
    "docs:api": "typedoc --options typedoc.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test": "npm run build && npm run test:unit && npm run test:integration"
  },
  "devDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
